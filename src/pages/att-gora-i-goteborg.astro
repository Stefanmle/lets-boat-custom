---
import { Image } from "astro:assets";
import Base from "@/layouts/Base.astro";
import { t } from "@/i18n";
import boatPhoto from "@/assets/images/boats-sunset.webp";
import mohippaImg from "@/assets/images/mohippa-bridge.webp";
import friendsImg from "@/assets/images/friends-harbor.webp";
import teambuildingImg from "@/assets/images/teambuilding.webp";
import afterworkImg from "@/assets/images/afterwork-group.webp";
import graduationImg from "@/assets/images/graduation-boat.webp";
import dejtImg from "@/assets/images/couple-dejt.webp";

const i = t();
const bookingUrl = "https://lets-boat.letsbook.app/sv-se/form/boats?boatModelId=f000715e-a251-42c5-b181-62566984bc42&dockId=e8fa42df-57d7-4d40-b5fd-6680c040d90e";

const activities = [
  {
    slug: "familjetur",
    title: "Familjetur – Pirater på kanalen!",
    text: "Alla man på däck! Ta med hela besättningen – stora som små – på en familjeäventyrstur genom Göteborgs kanaler. Barnen får styra, föräldrarna får njuta, och alla får vara kapten. Packa picknicken, hissa flaggan och ge er ut på det lugnaste äventyret till sjöss!",
    image: friendsImg,
  },
  {
    slug: "mohippa",
    title: "Möhippa – Bruden tar rodret!",
    text: "Ge bruden en möhippa i Göteborg som hon sent kommer att glömma! Samla brudgänget, packa bubblet och låt festen börja redan på bryggan. Vår elbåt är er privata festvåning på vattnet – med Göteborgs vackraste utsikt som kuliss. Inga sjömanskunskaper krävs, bara fest-humör!",
    image: mohippaImg,
  },
  {
    slug: "teambuilding-i-goteborg",
    title: "Teambuilding – Kapten & besättning!",
    text: "Dags att ta teamet från kontorsstolarna till kaptensstolen! Teambuilding i Göteborg på vattnet är det smartaste sättet att stärka sammanhållningen. Navigera genom kanalerna, utmana varandra i Göteborgs-quiz och bygg laganda medan stadsvyerna glider förbi. Chefen får inte bestämma farten!",
    image: teambuildingImg,
  },
  {
    slug: "afterwork",
    title: "Afterwork – Ankra upp och skåla!",
    text: "Glöm tråkiga afterwork-barer. Den bästa afterworken i Göteborg sker på vattnet! Häll upp favoritdrycken, kicka igång spellistan och låt stressen sjunka till botten medan ni kryssar genom Göteborgs kanaler i solnedgången. Det här är afterwork på en helt ny nivå.",
    image: afterworkImg,
  },
  {
    slug: "kompisarna",
    title: "Kompisgänget – Alla ombord!",
    text: "Samla gänget och ge er ut på Göteborgs bästa kompis-äventyr! Med plats för 12 sjöbjörnar är våra elbåtar perfekta för allt från lugna kanalturer till fartfyllda skrattsessioner. Ta med snacks, tunes och det goda humöret – resten fixar vi!",
    image: graduationImg,
  },
  {
    slug: "dejten",
    title: "Dejten – Romantik på vågorna!",
    text: "Letar du efter den perfekta dejt-idén i Göteborg? Champagne, solnedgång och en elegant elbåt som glider fram genom kanalerna. Imponera på din dejt med den mest romantiska upplevelsen staden har att erbjuda. Cupid har inget på Let's Boat.",
    image: dejtImg,
  },
];
---

<Base
  title="Att göra i Göteborg – Hyr elbåt med Let's Boat"
  description="Letar du efter saker att göra i Göteborg? Hyr en elbåt med Let's Boat och upplev staden från vattnet! Perfekt för familjer, kompisar, möhippor, teambuilding och romantiska dejter."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ocean pb-24 pt-32 sm:pb-32 sm:pt-44">
    <div class="absolute inset-0">
      <Image
        src={boatPhoto}
        alt="Elbåtar vid bryggan i Göteborg – att göra i Göteborg"
        class="h-full w-full object-cover opacity-25"
        widths={[480, 768, 1440]}
        sizes="100vw"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ocean/70 via-ocean/60 to-ocean/90"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl font-bold text-white sm:text-4xl md:text-5xl lg:text-6xl">
        Att göra i Göteborg?<br />
        <span class="bg-gradient-to-r from-cyan to-cyan-dark bg-clip-text text-transparent">Sätt kurs mot äventyret!</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/70">
        Ahoy, äventyrare! Letar du efter det bästa att göra i Göteborg? Glöm landkrabborna – det är på vattnet det händer. Styr din egen elbåt genom Göteborgs kanaler, helt utan körkort eller sjöerfarenhet. Bara ren glädje!
      </p>

      <div class="mx-auto mt-8 grid max-w-lg grid-cols-2 gap-3">
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Ingen licens krävs</span>
        </div>
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Upp till 12 personer</span>
        </div>
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Ta med egen mat & dryck</span>
        </div>
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">100% elektrisk & tyst</span>
        </div>
      </div>

      <p class="mt-6 font-heading text-xl font-bold text-white sm:text-2xl">Från 250 kr/person</p>
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center gap-2.5 rounded-full bg-cyan px-8 py-4 text-base font-bold text-ocean shadow-2xl shadow-cyan/30 transition-all hover:scale-105 hover:bg-cyan-dark"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Boka din elbåtstur nu
      </a>

      <!-- Review badges -->
      <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
        <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 backdrop-blur-md transition-colors hover:bg-white/20">
          <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <span class="text-sm font-semibold text-white">4.9</span>
          <div class="flex">{[1,2,3,4,5].map(() => (<svg class="h-3 w-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}</div>
          <span class="text-xs text-white/70">(126)</span>
        </a>
        <a href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 backdrop-blur-md transition-colors hover:bg-white/20">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#00AF87"/><circle cx="8.5" cy="12" r="2.5" fill="white"/><circle cx="15.5" cy="12" r="2.5" fill="white"/><circle cx="8.5" cy="12" r="1.2" fill="#00AF87"/><circle cx="15.5" cy="12" r="1.2" fill="#00AF87"/><path d="M12 7L14.5 9.5H9.5L12 7Z" fill="white"/></svg>
          <span class="text-sm font-semibold text-white">4.9</span>
          <div class="flex">{[1,2,3,4,5].map(() => (<svg class="h-3 w-3 text-tripadvisor" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}</div>
          <span class="text-xs text-white/70">(139)</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Intro SEO text -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-ocean sm:text-3xl">Göteborgs bästa aktivitet på vattnet</h2>
      <p class="mt-4 text-lg leading-relaxed text-text/80">
        Att göra i Göteborg – den eviga frågan! Staden har massor att erbjuda, men det finns en aktivitet som sticker ut mer än alla andra: att hyra en elbåt med Let's Boat och utforska Göteborgs kanaler på egen hand.
      </p>
      <p class="mt-4 leading-relaxed text-text/70">
        Tänk dig att glida fram i din egen båt genom vallgraven, förbi majestätiska byggnader och under historiska broar, medan solens strålar dansar på vattenytan. Ingen kaptenslicens behövs, ingen stress, bara ren och skär glädje på Göteborgs vatten. Våra elbåtar är helt tysta och miljövänliga – perfekta för dig som vill uppleva Göteborg från en helt ny vinkel.
      </p>
      <p class="mt-4 leading-relaxed text-text/70">
        Med plats för upp till 12 besättningsmedlemmar och friheten att ta med egen mat, dryck och alkohol är Let's Boat det perfekta valet oavsett om du planerar en familjedag, möhippa, teambuilding, afterwork, kompis-utflykt eller romantisk dejt. Letar du efter saker att göra i Göteborg? Sök inte längre – vi har ankrat upp och väntar på dig vid Lilla Bommen!
      </p>
    </div>
  </section>

  <!-- Activities grid -->
  <section class="bg-sand py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="text-sm font-semibold uppercase tracking-widest text-cyan-dark">Välj ditt äventyr</span>
        <h2 class="mt-3 font-heading text-3xl font-bold text-ocean sm:text-4xl">
          Sex anledningar att kliva ombord
        </h2>
        <p class="mt-3 text-text/70">Varje tur är unik – precis som din besättning</p>
      </div>

      <div class="mt-14 space-y-10">
        {activities.map((activity, idx) => (
          <a
            href={`/${activity.slug}`}
            class="group grid items-center gap-8 overflow-hidden rounded-2xl bg-white shadow-sm transition-all duration-500 hover:shadow-xl sm:grid-cols-2"
          >
            <div class:list={["relative h-64 overflow-hidden sm:h-80", idx % 2 === 1 && "sm:order-2"]}>
              <Image
                src={activity.image}
                alt={activity.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                widths={[400, 700]}
                sizes="(max-width: 640px) 100vw, 50vw"
              />
            </div>
            <div class="p-8">
              <h3 class="font-heading text-xl font-bold text-ocean sm:text-2xl">{activity.title}</h3>
              <p class="mt-3 leading-relaxed text-text/70">{activity.text}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-cyan-dark transition-colors group-hover:text-cyan">
                Läs mer & boka
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO bottom text + CTA -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-ocean sm:text-3xl">Varför Let's Boat är det bästa att göra i Göteborg</h2>
      <p class="mt-4 leading-relaxed text-text/70">
        Göteborg är en sjöfartsstad i hjärtat, och det bästa sättet att uppleva den är från vattnet. Medan andra turister promenerar längs Avenyn erbjuder vi dig chansen att se staden från den vinkel som göteborgarna själva älskar mest – från kanalerna.
      </p>
      <p class="mt-4 leading-relaxed text-text/70">
        Våra elbåtar är enkla att styra, helt tysta och 100% elektriska. Du bokar online på 30 sekunder, kliver ombord vid Lilla Bommen och ger dig ut på Göteborgs vatten. Inga kurser, inga certifikat, bara du och dina medseglare. Vi har blivit rankade 4.9 av 5 på Google med över 126 recensioner – det säger en del om upplevelsen som väntar!
      </p>
      <p class="mt-4 leading-relaxed text-text/70">
        Så nästa gång någon frågar "Vad ska man göra i Göteborg?" har du svaret: Let's Boat. Vi ses vid bryggan, kapten!
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-ocean py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">Redo att ge er ut på vattnet?</h2>
      <p class="mt-3 text-white/80">Boka er elbåt i Göteborg idag – det tar bara 30 sekunder</p>
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-cyan px-8 py-4 text-base font-bold text-ocean shadow-2xl shadow-cyan/30 transition-all hover:scale-105 hover:bg-cyan-dark"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Boka din tur nu
      </a>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
        <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-sm text-white/80 hover:bg-white/20">
          <svg class="h-3.5 w-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          4.9 Google (126)
        </a>
        <a href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html" target="_blank" rel="noopener" class="flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-sm text-white/80 hover:bg-white/20">
          <svg class="h-3.5 w-3.5 text-tripadvisor" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          4.9 TripAdvisor (139)
        </a>
      </div>
    </div>
  </section>
</Base>
