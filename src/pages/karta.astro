---
import { Image } from "astro:assets";
import Base from "@/layouts/Base.astro";
import { t } from "@/i18n";
import mapImg from "@/assets/images/map-routes.webp";

const i = t();

---

<Base
  title="Karta – Let's Boat Göteborg"
  description="Se kartan över Let's Boat i Göteborg. Hitta våra bryggor och se var du kan navigera med din elbåt."
>
  <section class="relative overflow-hidden bg-ocean pb-16 pt-32 sm:pb-20 sm:pt-40">
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl font-bold text-white sm:text-4xl md:text-5xl">
        Karta över Göteborgs kanaler
      </h1>
      <p class="mt-4 text-lg text-white/70">Se var du kan navigera med våra elbåtar</p>
    </div>
  </section>

  <!-- Canal route map -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-2xl border border-sand-dark shadow-xl">
        <Image
          src={mapImg}
          alt="Karta över Göteborgs kanaler och Let's Boat navigeringsområde"
          class="w-full"
          widths={[600, 900, 1200]}
          sizes="(max-width: 1024px) 100vw, 900px"
        />
      </div>
      <p class="mt-4 text-center text-sm text-text/50">Karta uppdaterad oktober 2025 – Navigeringsområde markerat i kartan</p>
    </div>
  </section>

  <!-- Single dock info -->
  <section class="bg-sand py-16 sm:py-24">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-ocean sm:text-3xl">Vår brygga</h2>
      <p class="mt-3 text-text/60">Vi utgår från Lilla Bommen, i hjärtat av Göteborg</p>
      <div class="mt-6 inline-flex items-center gap-3 rounded-xl border border-sand-dark bg-white px-6 py-4">
        <svg class="h-6 w-6 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <div class="text-left">
          <p class="font-semibold text-ocean">Christina Nilssons gata 1, 411 04 Göteborg</p>
          <p class="text-sm text-text/50">Lilla Bommen – Let's Boat</p>
        </div>
      </div>
      <div class="mt-4">
        <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm font-semibold text-cyan-dark hover:text-cyan">
          Öppna i Google Maps
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>
</Base>
