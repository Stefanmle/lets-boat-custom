---
import Base from "@/layouts/Base.astro";
import { t } from "@/i18n";
const i = t();
---

<Base
  title="Kontakt – Let's Boat Göteborg"
  description="Kontakta Let's Boat i Göteborg. Ring, maila eller besök oss vid Lilla Bommen."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ocean pb-16 pt-32 sm:pb-20 sm:pt-40">
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl font-bold text-white sm:text-4xl md:text-5xl">
        {i.contact.title}
      </h1>
      <p class="mt-4 text-lg text-white/70">{i.contact.subtitle}</p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Contact info -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-ocean">Ring eller skriv till oss!</h2>
          <p class="mt-3 text-text/70">Vi hjälper dig mer än gärna med frågor eller andra ärenden.</p>

          <div class="mt-8 space-y-6">
            <a href={`tel:${i.contact.phone.replace(/\s/g, "")}`} class="flex items-center gap-4 rounded-xl border border-sand-dark bg-sand p-5 transition-colors hover:border-cyan/30">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-cyan/10">
                <svg class="h-6 w-6 text-ocean" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-text/50">Telefon</p>
                <p class="text-lg font-semibold text-ocean">{i.contact.phone}</p>
              </div>
            </a>

            <a href={`mailto:${i.contact.email}`} class="flex items-center gap-4 rounded-xl border border-sand-dark bg-sand p-5 transition-colors hover:border-cyan/30">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-cyan/10">
                <svg class="h-6 w-6 text-ocean" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-text/50">E-post</p>
                <p class="text-lg font-semibold text-ocean">{i.contact.email}</p>
              </div>
            </a>

            <div class="flex items-center gap-4 rounded-xl border border-sand-dark bg-sand p-5">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-cyan/10">
                <svg class="h-6 w-6 text-ocean" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-text/50">Adress</p>
                <p class="text-lg font-semibold text-ocean">{i.contact.address}</p>
              </div>
            </div>
          </div>

          <!-- Map link -->
          <a
            href="https://www.google.com/maps?q=57.7065012,11.9677112"
            target="_blank"
            rel="noopener"
            class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-cyan-dark transition-colors hover:text-cyan"
          >
            Öppna i Google Maps
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Contact form -->
        <div>
          <form class="rounded-2xl border border-sand-dark bg-sand p-8" action="https://formsubmit.co/info@letsboat.se" method="POST">
            <input type="hidden" name="_subject" value="Nytt meddelande från letsboat.se" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="text" name="_honey" style="display:none" />

            <div class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium text-ocean">{i.contact.form.name}</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="mt-1.5 block w-full rounded-lg border border-sand-dark bg-white px-4 py-3 text-sm text-text shadow-sm transition-colors focus:border-cyan focus:outline-none focus:ring-2 focus:ring-cyan/20"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-ocean">{i.contact.form.email}</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-1.5 block w-full rounded-lg border border-sand-dark bg-white px-4 py-3 text-sm text-text shadow-sm transition-colors focus:border-cyan focus:outline-none focus:ring-2 focus:ring-cyan/20"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-ocean">{i.contact.form.message}</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="mt-1.5 block w-full rounded-lg border border-sand-dark bg-white px-4 py-3 text-sm text-text shadow-sm transition-colors focus:border-cyan focus:outline-none focus:ring-2 focus:ring-cyan/20"
                ></textarea>
              </div>
              <button
                type="submit"
                class="flex w-full items-center justify-center gap-2 rounded-full bg-cyan px-6 py-3.5 text-sm font-semibold text-ocean shadow-lg shadow-cyan/25 transition-all hover:bg-cyan-dark"
              >
                {i.contact.form.send}
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>
