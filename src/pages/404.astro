---
import Base from "@/layouts/Base.astro";
---

<Base title="Sidan hittades inte – Let's Boat" description="Sidan du söker finns inte.">
  <section class="flex min-h-[60vh] items-center justify-center bg-sand pt-20">
    <div class="px-4 text-center">
      <p class="text-7xl font-bold text-cyan">404</p>
      <h1 class="mt-4 font-heading text-2xl font-bold text-ocean sm:text-3xl">
        Sidan hittades inte
      </h1>
      <p class="mt-3 text-text/70">Sidan du letar efter verkar ha seglat iväg.</p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-cyan px-6 py-3 text-sm font-semibold text-ocean shadow-lg shadow-cyan/25 transition-all hover:bg-cyan-dark"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Tillbaka till startsidan
      </a>
    </div>
  </section>
</Base>
