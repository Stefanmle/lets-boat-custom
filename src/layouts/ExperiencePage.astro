---
import { Image } from "astro:assets";
import Base from "./Base.astro";
import { t } from "@/i18n";

interface Props {
  slug: keyof typeof import("@/i18n/sv").default.experiencePages;
}

const { slug } = Astro.props;
const i = t();
const page = i.experiencePages[slug];
const bookingUrl = "https://lets-boat.letsbook.app/sv-se/form/boats?boatModelId=f000715e-a251-42c5-b181-62566984bc42&dockId=e8fa42df-57d7-4d40-b5fd-6680c040d90e";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/*.webp"
);

const imgKey = `../assets/images/${page.image}.webp`;
const heroImage = images[imgKey] ? (await images[imgKey]()).default : null;
---

<Base title={page.metaTitle} description={page.metaDescription}>
  <!-- Hero with large background image -->
  <section class="relative overflow-hidden bg-ocean pb-24 pt-32 sm:pb-32 sm:pt-44">
    {heroImage && (
      <div class="absolute inset-0">
        <Image
          src={heroImage}
          alt={page.hero}
          class="h-full w-full object-cover opacity-30"
          widths={[480, 768, 1440]}
          sizes="100vw"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-ocean/70 via-ocean/60 to-ocean/90"></div>
      </div>
    )}
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <a
        href="/#upplevelser"
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-4 py-1.5 text-xs font-medium text-white/70 backdrop-blur-sm transition-colors hover:bg-white/10"
      >
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Alla upplevelser
      </a>
      <h1 class="font-heading text-2xl font-bold text-white sm:text-4xl md:text-5xl lg:text-6xl">
        {page.hero}
      </h1>

      <!-- Trust signals - hidden on mobile, shown on sm+ -->
      <div class="mx-auto mt-8 hidden max-w-lg grid-cols-2 gap-3 sm:grid">
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Ingen licens krävs</span>
        </div>
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Upp till 12 personer</span>
        </div>
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Egen mat, dryck & alkohol</span>
        </div>
        <div class="flex items-center gap-2 rounded-lg bg-white/10 px-4 py-2.5 backdrop-blur-sm">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm text-white/90">Fri avbokning 24h före</span>
        </div>
      </div>

      <!-- Mobile: compact feature line -->
      <p class="mt-3 text-xs text-white/60 sm:hidden">Ingen licens &bull; 12 pers &bull; BYOB &bull; Fri avbokning</p>

      <!-- Price + CTA -->
      <p class="mt-3 text-base font-bold text-white sm:mt-6 sm:text-2xl">Från 250 kr/person</p>

      <div class="mt-4 flex flex-col items-center gap-3 sm:mt-6 sm:flex-row sm:justify-center">
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-cyan px-7 py-3.5 text-base font-bold text-ocean shadow-2xl shadow-cyan/30 transition-all hover:scale-105 hover:bg-cyan-dark sm:px-8 sm:py-4"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          {page.cta}
        </a>
        <a href="/sa-har-gor-du" class="hidden items-center gap-2 rounded-full border border-white/20 px-6 py-3.5 text-sm font-medium text-white/80 transition-all hover:bg-white/10 sm:inline-flex">
          Så här gör du
        </a>
      </div>

      <!-- Social proof line -->
      <div class="mt-4 flex flex-wrap items-center justify-center gap-2 sm:mt-5 sm:gap-4">
        <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-xs text-white/70 backdrop-blur-sm transition-colors hover:bg-white/20 sm:text-sm">
          <svg class="h-3.5 w-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          4.9 på Google (126 omdömen)
        </a>
        <a href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html" target="_blank" rel="noopener" class="flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-xs text-white/70 backdrop-blur-sm transition-colors hover:bg-white/20 sm:text-sm">
          <svg class="h-3.5 w-3.5 text-[#00AF87]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          4.9 på TripAdvisor (139 omdömen)
        </a>
        <span class="text-xs text-white/70 sm:text-sm">100% Elektrisk</span>
      </div>
    </div>
  </section>

  <!-- Main content with large side image -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
        <!-- Text -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-ocean sm:text-3xl">{page.title}</h2>
          <p class="mt-4 text-lg leading-relaxed text-text/80">{page.intro}</p>
          {"introExtra" in page && page.introExtra && (
            <p class="mt-4 leading-relaxed text-text/70">{page.introExtra}</p>
          )}
          {"introExtra2" in page && page.introExtra2 && (
            <p class="mt-4 leading-relaxed text-text/70">{page.introExtra2}</p>
          )}
          {"introExtra3" in page && page.introExtra3 && (
            <p class="mt-4 leading-relaxed text-text/70">{page.introExtra3}</p>
          )}

          <!-- Trust signals -->
          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <div class="flex items-center gap-3 rounded-lg bg-sand p-3">
              <svg class="h-5 w-5 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm font-medium text-text/70">Ingen licens krävs</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg bg-sand p-3">
              <svg class="h-5 w-5 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm font-medium text-text/70">Upp till 12 personer</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg bg-sand p-3">
              <svg class="h-5 w-5 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm font-medium text-text/70">Egen mat, dryck & alkohol</span>
            </div>
            <div class="flex items-center gap-3 rounded-lg bg-sand p-3">
              <svg class="h-5 w-5 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm font-medium text-text/70">Fri avbokning 24h före</span>
            </div>
          </div>
        </div>

        <!-- Large image -->
        {heroImage && (
          <div class="relative">
            <Image
              src={heroImage}
              alt={page.title}
              class="w-full rounded-2xl shadow-2xl"
              widths={[480, 700, 900]}
              sizes="(max-width: 1024px) 100vw, 50vw"
            />
            <!-- Floating rating badges -->
            <div class="absolute -bottom-4 -left-4 flex flex-col gap-2 sm:-bottom-6 sm:-left-6">
              <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-xl bg-white px-3.5 py-2.5 shadow-lg transition-shadow hover:shadow-xl">
                <span class="text-xl font-bold text-ocean">4.9</span>
                <div>
                  <div class="flex">
                    {[1,2,3,4,5].map(() => (
                      <svg class="h-3 w-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    ))}
                  </div>
                  <p class="text-[10px] text-text/50">Google</p>
                </div>
              </a>
              <a href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-xl bg-white px-3.5 py-2.5 shadow-lg transition-shadow hover:shadow-xl">
                <span class="text-xl font-bold text-[#00AF87]">4.9</span>
                <div>
                  <div class="flex">
                    {[1,2,3,4,5].map(() => (
                      <svg class="h-3 w-3 text-[#00AF87]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    ))}
                  </div>
                  <p class="text-[10px] text-text/50">TripAdvisor</p>
                </div>
              </a>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Section 2 - full width highlight -->
  <section class="bg-sand py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-ocean sm:text-3xl">{page.section2Title}</h2>
      <p class="mt-4 text-lg leading-relaxed text-text/70">{page.section2Text}</p>
      {"section2Extra" in page && page.section2Extra && (
        <p class="mt-4 leading-relaxed text-text/70">{page.section2Extra}</p>
      )}
      {"section2Extra2" in page && page.section2Extra2 && (
        <p class="mt-4 leading-relaxed text-text/70">{page.section2Extra2}</p>
      )}
      {"section2Extra3" in page && page.section2Extra3 && (
        <p class="mt-4 leading-relaxed text-text/70">{page.section2Extra3}</p>
      )}
      {"section2Extra4" in page && page.section2Extra4 && (
        <p class="mt-4 leading-relaxed text-text/70">{page.section2Extra4}</p>
      )}
    </div>
  </section>

  <!-- Pricing teaser + CTA -->
  <section class="bg-ocean py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">Priser från 250 kr/person</h2>
      <p class="mt-3 text-white/60">Välj mellan 1, 2 eller 3 timmars tur. Lyxiga 12-sitsbåtar med allt du behöver.</p>

      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-cyan px-8 py-4 text-base font-bold text-ocean shadow-2xl shadow-cyan/30 transition-all hover:scale-105 hover:bg-cyan-dark"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          {page.cta}
        </a>
        <a href="/sa-har-gor-du" class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3.5 text-sm font-medium text-white/80 transition-all hover:bg-white/10">
          Så här gör du
        </a>
      </div>

      <!-- Quick social proof -->
      <div class="mt-8 flex items-center justify-center gap-6 text-sm text-white/70">
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          4.9 på Google (126 omdömen)
        </span>
        <span>100% Elektrisk</span>
        <span>Fri avbokning</span>
      </div>
    </div>
  </section>
</Base>
