---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage = "/og-image.jpg", canonical } = Astro.props;
const siteUrl = import.meta.env.SITE ?? Astro.site?.href ?? "https://lets-boat-custom.vercel.app";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="style" href="/fonts/fonts.css" />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="sv_SE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Let's Boat",
      "description": "Hyr elbåt i Göteborg – upplev staden från vattnet!",
      "url": "https://letsboat.se",
      "telephone": "+46319911111",
      "email": "info@letsboat.se",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Christina Nilssons gata 1",
        "addressLocality": "Göteborg",
        "postalCode": "411 04",
        "addressCountry": "SE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 57.7065012,
        "longitude": 11.9677112
      },
      "priceRange": "250-2295 SEK",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]
      }
    })} />
  </head>
  <body class="flex min-h-screen flex-col bg-white text-text antialiased pb-16 lg:pb-0">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      // Scroll to top on page load (handles navigation between pages)
      window.addEventListener("load", () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
        }
      });
      // Also handle Astro page transitions if used in the future
      document.addEventListener("astro:after-swap", () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
        }
      });
    </script>
  </body>
</html>
