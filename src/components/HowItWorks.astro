---
import { t } from "@/i18n";
const i = t();
---

<section class="relative overflow-hidden bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-cyan-dark">{i.howItWorks.subtitle}</span>
      <h2 class="mt-3 font-heading text-3xl font-bold text-ocean sm:text-4xl lg:text-5xl">
        {i.howItWorks.title}
      </h2>
    </div>

    <!-- Steps -->
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {i.howItWorks.steps.map((step, idx) => (
        <div class="relative">
          {/* Connector line */}
          {idx < 2 && (
            <div class="absolute left-1/2 top-12 hidden h-0.5 w-full bg-gradient-to-r from-cyan/30 to-cyan/10 lg:block"></div>
          )}
          <div class="relative flex flex-col items-center text-center">
            {/* Number circle */}
            <div class="relative z-10 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-ocean to-ocean-light shadow-xl shadow-ocean/20">
              <span class="font-heading text-3xl font-bold text-cyan">{step.number}</span>
            </div>
            <h3 class="mt-6 font-heading text-xl font-bold text-ocean">{step.title}</h3>
            <p class="mt-3 max-w-xs text-sm leading-relaxed text-text/70">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
