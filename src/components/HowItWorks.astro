---
import { t } from "@/i18n";
const i = t();
---

<section class="relative overflow-hidden bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-cyan-dark">{i.howItWorks.subtitle}</span>
      <h2 class="mt-3 font-heading text-3xl font-bold text-ocean sm:text-4xl lg:text-5xl">
        {i.howItWorks.title}
      </h2>
    </div>

    <div class="relative mt-16 grid gap-8 lg:grid-cols-3 lg:gap-12">
      <!-- Connector line (desktop) -->
      <div class="absolute left-[16.6%] right-[16.6%] top-8 hidden h-0.5 bg-gradient-to-r from-cyan/10 via-cyan/30 to-cyan/10 lg:block"></div>

      {i.howItWorks.steps.map((step, idx) => (
        <div class="relative flex flex-col items-center text-center">
          <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-full bg-ocean shadow-lg">
            {idx === 0 && (
              <svg class="h-7 w-7 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-3.75h.008v.008H12v-.008zM9 15l2 2 4-4"/></svg>
            )}
            {idx === 1 && (
              <svg class="h-7 w-7 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>
            )}
            {idx === 2 && (
              <svg class="h-7 w-7 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v10M12 3l5 8H7l5-8z" fill="currentColor" opacity="0.2" stroke="none"/><path d="M12 3v10M7 13l5-8 5 8"/><path d="M3 17c2 2 4 3 6 3s4-1 6-3c2-2 4-3 6-3"/><path d="M3 21c2 2 4 3 6 3s4-1 6-3c2-2 4-3 6-3" opacity="0.5"/></svg>
            )}
          </div>
          <h3 class="mt-5 font-heading text-xl font-bold text-ocean sm:text-2xl">{step.title}</h3>
          <p class="mt-3 max-w-sm text-base leading-relaxed text-text/70">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
