---
import { t } from "@/i18n";
const i = t();
---

<section class="relative overflow-hidden bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-cyan-dark">{i.howItWorks.subtitle}</span>
      <h2 class="mt-3 font-heading text-3xl font-bold text-ocean sm:text-4xl lg:text-5xl">
        {i.howItWorks.title}
      </h2>
    </div>

    <div class="relative mt-16 grid gap-8 lg:grid-cols-3 lg:gap-12">
      <!-- Connector line (desktop) -->
      <div class="absolute left-[16.6%] right-[16.6%] top-8 hidden h-0.5 bg-gradient-to-r from-cyan/10 via-cyan/30 to-cyan/10 lg:block"></div>

      {i.howItWorks.steps.map((step) => (
        <div class="relative flex flex-col items-center text-center">
          <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-full bg-ocean text-2xl font-bold text-cyan shadow-lg">
            {step.number}
          </div>
          <h3 class="mt-5 font-heading text-xl font-bold text-ocean sm:text-2xl">{step.title}</h3>
          <p class="mt-3 max-w-sm text-base leading-relaxed text-text/70">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
