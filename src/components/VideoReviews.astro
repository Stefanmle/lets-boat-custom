---
const googleUrl = "https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6";
const tripAdvisorUrl = "https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html";

const reviews = [
  {
    name: "Gaute Brynildsen",
    text: "We were two adults and two boys who rented a boat for one hour. Totally without emissions, pure electric ❤️ Great way to see Gothenburg from the canals!",
    rating: 5,
    source: "Google",
    sourceUrl: googleUrl,
  },
  {
    name: "Romain Rascle",
    text: "Such a fun experience in Gothenburg! Super easy to book and even easier to steer. Perfect way to explore the canals at your own pace.",
    rating: 5,
    source: "TripAdvisor",
    sourceUrl: tripAdvisorUrl,
  },
  {
    name: "Thomas Seillan",
    text: "We've had great fun and really enjoyed the service. It allowed us to discover Göteborg on our own. Highly recommend!",
    rating: 5,
    source: "Google",
    sourceUrl: googleUrl,
  },
  {
    name: "Joe Mendoza",
    text: "This experience was unbelievable. I even snuck in a surprise proposal that we will never forget. Absolutely magical on the water!",
    rating: 5,
    source: "Google",
    sourceUrl: googleUrl,
  },
  {
    name: "Gilberto Lucas",
    text: "Absolutely a MUST do if you're in town. Well organized, easy to book and with kind people. A unique way to see the city!",
    rating: 5,
    source: "TripAdvisor",
    sourceUrl: tripAdvisorUrl,
  },
  {
    name: "Atdhe Haxhibeqiri",
    text: "Really worth it. You can have the boat for yourselves and it is extremely easy to drive. Perfect for families and groups!",
    rating: 5,
    source: "Google",
    sourceUrl: googleUrl,
  },
];
---

<section class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

    <!-- Rating badges -->
    <div class="mx-auto mb-14 flex flex-col items-center justify-center gap-6 sm:flex-row sm:gap-10">
      <!-- Google badge -->
      <a href={googleUrl} target="_blank" rel="noopener" class="flex items-center gap-4 rounded-2xl border border-sand-dark bg-sand px-6 py-4 transition-all hover:shadow-lg">
        <svg class="h-10 w-10" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-text">Google Reviews</p>
          <div class="flex items-center gap-2">
            <span class="text-2xl font-bold text-ocean">4.9</span>
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-xs text-text/50">126 omdömen</span>
          </div>
        </div>
      </a>

      <!-- TripAdvisor badge -->
      <a href={tripAdvisorUrl} target="_blank" rel="noopener" class="flex items-center gap-4 rounded-2xl border border-sand-dark bg-sand px-6 py-4 transition-all hover:shadow-lg">
        <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="12" fill="#00AF87"/>
          <circle cx="8.5" cy="12" r="2.5" fill="white"/>
          <circle cx="15.5" cy="12" r="2.5" fill="white"/>
          <circle cx="8.5" cy="12" r="1.2" fill="#00AF87"/>
          <circle cx="15.5" cy="12" r="1.2" fill="#00AF87"/>
          <path d="M12 7L14.5 9.5H9.5L12 7Z" fill="white"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-text">TripAdvisor</p>
          <div class="flex items-center gap-2">
            <span class="text-2xl font-bold text-[#00AF87]">4.9</span>
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg class="h-4 w-4 text-[#00AF87]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-xs text-text/50">139 omdömen</span>
          </div>
        </div>
      </a>
    </div>

    <!-- Review cards -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {reviews.map((review) => (
        <a
          href={review.sourceUrl}
          target="_blank"
          rel="noopener"
          class="group rounded-2xl border border-sand-dark bg-sand p-6 transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1">
              {Array.from({length: review.rating}).map(() => (
                <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class:list={[
              "rounded-full px-2 py-0.5 text-[10px] font-semibold",
              review.source === "Google" ? "bg-blue-50 text-blue-600" : "bg-green-50 text-[#00AF87]",
            ]}>
              {review.source}
            </span>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-text/70">"{review.text}"</p>
          <p class="mt-3 text-xs font-semibold text-ocean">— {review.name}</p>
        </a>
      ))}
    </div>

    <!-- See all reviews links -->
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href={googleUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm font-semibold text-ocean transition-colors hover:text-cyan-dark">
        Alla Google-omdömen
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
      <a href={tripAdvisorUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm font-semibold text-[#00AF87] transition-colors hover:text-green-700">
        Alla TripAdvisor-omdömen
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </div>
</section>
