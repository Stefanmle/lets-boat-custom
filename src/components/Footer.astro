---
import { Image } from "astro:assets";
import logoWhite from "@/assets/images/logo-white.webp";
import { t } from "@/i18n";
const i = t();
const year = new Date().getFullYear();
---

<footer class="bg-ocean text-white">
  <!-- Wave separator -->
  <div class="relative -mb-px">
    <svg viewBox="0 0 1440 80" fill="none" class="w-full" preserveAspectRatio="none">
      <path
        d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z"
        fill="#253861"
      />
    </svg>
  </div>

  <div class="mx-auto max-w-7xl px-4 pb-8 pt-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <Image src={logoWhite} alt="Let's Boat" class="h-8 w-auto" widths={[160, 240]} sizes="240px" />
        <p class="mt-3 text-sm text-white/70">{i.footer.tagline}</p>
        <!-- Social Links -->
        <div class="mt-5 flex gap-3">
          <a
            href="https://www.instagram.com/letsboatgoteborg/"
            target="_blank"
            rel="noopener"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-cyan/20"
            aria-label="Instagram"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a
            href="https://www.facebook.com/Letsboatgoteborg/"
            target="_blank"
            rel="noopener"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-cyan/20"
            aria-label="Facebook"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a
            href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html"
            target="_blank"
            rel="noopener"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-cyan/20"
            aria-label="TripAdvisor"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 004.04 10.43 5.976 5.976 0 004.003-1.533 5.976 5.976 0 004.003 1.533 5.997 5.997 0 004.04-10.43L20 6.648h-4.35a14.22 14.22 0 00-3.644-2.353zM6.003 17.213a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zm11.994 0a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zM6.003 11.219a2 2 0 100 4 2 2 0 000-4zm11.994 0a2 2 0 100 4 2 2 0 000-4z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">{i.nav.experiences}</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/familjetur" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.family}</a></li>
          <li><a href="/mohippa" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.bachelorette}</a></li>
          <li><a href="/teambuilding" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.teambuilding}</a></li>
          <li><a href="/afterwork" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.afterwork}</a></li>
          <li><a href="/kompisarna" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.friends}</a></li>
          <li><a href="/dejten" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.date}</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">Information</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/sa-har-gor-du" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.howItWorks}</a></li>
          <li><a href="/kontakt" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.contact}</a></li>
          <li><a href="/karta" class="text-sm text-white/70 transition-colors hover:text-cyan">{i.nav.map}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">{i.nav.contact}</h3>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm text-white/70">{i.contact.address}</span>
          </li>
          <li>
            <a href={`tel:${i.contact.phone.replace(/\s/g, "")}`} class="flex items-center gap-3 text-sm text-white/70 transition-colors hover:text-cyan">
              <svg class="h-4 w-4 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {i.contact.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${i.contact.email}`} class="flex items-center gap-3 text-sm text-white/70 transition-colors hover:text-cyan">
              <svg class="h-4 w-4 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {i.contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
      <p class="text-xs text-white/40">{i.footer.copyright.replace("{year}", String(year))}</p>
      <div class="flex items-center gap-4">
        <a href="/bokningsvillkor" class="text-xs text-white/40 transition-colors hover:text-white/70">{i.footer.bookingTerms}</a>
        <!-- Payment icons -->
        <div class="flex items-center gap-2">
          <!-- Visa -->
          <svg class="h-8 w-12 rounded bg-white/10 p-1" viewBox="0 0 48 32" fill="none">
            <rect width="48" height="32" rx="4" fill="white" fill-opacity="0.1"/>
            <path d="M20.3 21.2l2.3-14h3.7l-2.3 14h-3.7zm15.5-14l-3.5 9.6-.4-2-1.2-6.2s-.1-1.4-1.8-1.4h-5.6l-.1.3s1.9.4 4.1 1.8l3.4 13h3.8l5.8-15.1h-4.5zm-22.2 0l-3.6 9.5-.4-1.9c-.7-2.3-2.8-4.9-5.2-6.2l3.2 12.6h3.8l5.8-14h-3.6z" fill="white"/>
            <path d="M11.6 7.2H6l-.1.3c4.5 1.2 7.5 4 8.8 7.4l-1.3-6.5s-.2-1.2-1.8-1.2z" fill="#F7B600"/>
          </svg>
          <!-- Mastercard -->
          <svg class="h-8 w-12 rounded bg-white/10 p-1" viewBox="0 0 48 32" fill="none">
            <rect width="48" height="32" rx="4" fill="white" fill-opacity="0.1"/>
            <circle cx="19" cy="16" r="8" fill="#EB001B" opacity="0.8"/>
            <circle cx="29" cy="16" r="8" fill="#F79E1B" opacity="0.8"/>
            <path d="M24 10.3a7.96 7.96 0 000 11.4 7.96 7.96 0 000-11.4z" fill="#FF5F00" opacity="0.8"/>
          </svg>
          <!-- Amex -->
          <svg class="h-8 w-12 rounded bg-white/10 p-1" viewBox="0 0 48 32" fill="none">
            <rect width="48" height="32" rx="4" fill="white" fill-opacity="0.1"/>
            <rect x="4" y="6" width="40" height="20" rx="2" fill="#2E77BC" opacity="0.8"/>
            <text x="24" y="19" text-anchor="middle" fill="white" font-size="8" font-weight="bold" font-family="sans-serif">AMEX</text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</footer>
