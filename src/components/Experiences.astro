---
import { Image } from "astro:assets";
import { t } from "@/i18n";
const i = t();

import mohippaImg from "@/assets/images/mohippa-bridge.webp";
import friendsImg from "@/assets/images/friends-harbor.webp";
import boatsSunsetImg from "@/assets/images/boats-sunset.webp";
import afterworkImg from "@/assets/images/afterwork-group.webp";
import graduationImg from "@/assets/images/graduation-boat.webp";
import dejtImg from "@/assets/images/couple-dejt.webp";

const cardData: Record<string, ImageMetadata> = {
  familjetur: boatsSunsetImg,
  mohippa: mohippaImg,
  teambuilding: graduationImg,
  afterwork: afterworkImg,
  kompisarna: friendsImg,
  dejten: dejtImg,
};
---

<section id="upplevelser" class="relative overflow-hidden bg-sand py-20 sm:py-28">
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: radial-gradient(circle at 1px 1px, #253861 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Review badges -->
    <div class="mx-auto mb-10 flex flex-row items-center justify-center gap-4 sm:gap-6">
      <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-2xl border border-sand-dark bg-white px-4 py-3 shadow-sm transition-all hover:shadow-md sm:px-6 sm:py-4">
        <svg class="h-8 w-8 sm:h-10 sm:w-10" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <div>
          <p class="text-xs font-semibold text-text sm:text-sm">Google Reviews</p>
          <div class="flex items-center gap-1.5">
            <span class="text-lg font-bold text-ocean sm:text-2xl">4.9</span>
            <div class="flex">{[1,2,3,4,5].map(() => (<svg class="h-3.5 w-3.5 text-yellow-400 sm:h-4 sm:w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}</div>
            <span class="hidden text-xs text-text/70 sm:inline">126 omdömen</span>
          </div>
        </div>
      </a>
      <a href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-2xl border border-sand-dark bg-white px-4 py-3 shadow-sm transition-all hover:shadow-md sm:px-6 sm:py-4">
        <svg class="h-8 w-8 sm:h-10 sm:w-10" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#00AF87"/><circle cx="8.5" cy="12" r="2.5" fill="white"/><circle cx="15.5" cy="12" r="2.5" fill="white"/><circle cx="8.5" cy="12" r="1.2" fill="#00AF87"/><circle cx="15.5" cy="12" r="1.2" fill="#00AF87"/><path d="M12 7L14.5 9.5H9.5L12 7Z" fill="white"/></svg>
        <div>
          <p class="text-xs font-semibold text-text sm:text-sm">TripAdvisor</p>
          <div class="flex items-center gap-1.5">
            <span class="text-lg font-bold text-[#00AF87] sm:text-2xl">4.9</span>
            <div class="flex">{[1,2,3,4,5].map(() => (<svg class="h-3.5 w-3.5 text-[#00AF87] sm:h-4 sm:w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>))}</div>
            <span class="hidden text-xs text-text/70 sm:inline">139 omdömen</span>
          </div>
        </div>
      </a>
    </div>

    <!-- Review quote (real Swedish TripAdvisor review) -->
    <div class="mx-auto mb-6 max-w-lg rounded-xl border border-sand-dark bg-white px-5 py-3 text-center shadow-sm sm:px-6 sm:py-4">
      <p class="text-sm italic text-text/80">"Otroligt trevliga och hjälpsamma! Toppenservice från början till slut. En fantastisk upplevelse – starkt rekommenderar båtturen med Let's Boat!"</p>
      <p class="mt-1 text-xs text-text/70">— Tugba G. via TripAdvisor</p>
    </div>

    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-cyan-dark">{i.experiences.subtitle}</span>
      <h2 class="mt-3 font-heading text-3xl font-bold text-ocean sm:text-4xl lg:text-5xl">
        {i.experiences.title}
      </h2>
    </div>

    <div class="mt-14 flex snap-x snap-mandatory gap-4 overflow-x-auto pl-4 pr-4 pb-4 sm:grid sm:snap-none sm:grid-cols-2 sm:gap-5 sm:overflow-visible sm:pl-0 sm:pr-0 sm:pb-0 lg:grid-cols-3">
      {i.experiences.items.map((item) => (
        <a
          href={`/${item.slug}`}
          class="group relative w-[280px] flex-shrink-0 snap-start overflow-hidden rounded-2xl bg-white shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:shadow-2xl sm:w-auto"
        >
          <div class="relative h-48 overflow-hidden sm:h-64">
            {cardData[item.slug] && (
              <Image
                src={cardData[item.slug]}
                alt={item.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                widths={[400, 600]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-ocean/80 via-ocean/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="font-heading text-xl font-bold text-white drop-shadow-lg">{item.title}</h3>
              <p class="mt-1 text-sm text-white/80 drop-shadow">{item.description}</p>
            </div>
          </div>
          <div class="flex items-center justify-between px-5 py-4">
            <span class="text-sm font-semibold text-cyan-dark transition-colors group-hover:text-cyan">
              Läs mer
            </span>
            <svg class="h-5 w-5 text-cyan-dark transition-transform group-hover:translate-x-1 group-hover:text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
