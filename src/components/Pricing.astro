---
import { t } from "@/i18n";
const i = t();
---

<section id="priser" class="relative overflow-hidden bg-ocean py-20 sm:py-28">
  <!-- Wave top -->
  <div class="absolute -top-px left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" class="w-full" preserveAspectRatio="none">
      <path d="M0 60V20C240 60 480 0 720 20C960 40 1200 0 1440 20V60H0Z" fill="#253861"/>
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-cyan">{i.pricing.subtitle}</span>
      <h2 class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {i.pricing.title}
      </h2>
    </div>

    <!-- Cards -->
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {i.pricing.durations.map((plan) => (
        <div class:list={[
          "relative overflow-hidden rounded-2xl p-[1px]",
          plan.popular
            ? "bg-gradient-to-b from-cyan to-cyan/30"
            : "bg-white/10",
        ]}>
          {plan.popular && (
            <div class="absolute left-1/2 top-0 z-10 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan px-5 py-1.5 text-xs font-bold uppercase tracking-wider text-ocean shadow-lg shadow-cyan/30">
              Mest populär
            </div>
          )}
          <div class:list={[
            "relative h-full rounded-2xl p-8",
            plan.popular ? "bg-ocean-light" : "bg-ocean-light/60",
          ]}>
            <h3 class="font-heading text-2xl font-bold text-white">{plan.label}</h3>

            <div class="mt-6 space-y-4">
              <div class="rounded-xl bg-white/5 p-4">
                <p class="text-xs font-medium uppercase tracking-wider text-white/70">{plan.smallLabel}</p>
                <p class="mt-1 text-2xl font-bold text-cyan">{plan.priceSmall}</p>
              </div>
              <div class="rounded-xl bg-white/5 p-4">
                <p class="text-xs font-medium uppercase tracking-wider text-white/70">{plan.largeLabel}</p>
                <p class="mt-1 text-2xl font-bold text-white">{plan.priceLarge}</p>
              </div>
            </div>

            <a
              href="https://lets-boat.letsbook.app/sv-se/form/boats?boatModelId=f000715e-a251-42c5-b181-62566984bc42&dockId=e8fa42df-57d7-4d40-b5fd-6680c040d90e" target="_blank" rel="noopener"
              class:list={[
                "mt-8 flex w-full items-center justify-center gap-2 rounded-full py-3.5 text-sm font-semibold transition-all",
                plan.popular
                  ? "bg-cyan text-ocean shadow-lg shadow-cyan/25 hover:bg-cyan-dark"
                  : "border border-white/20 text-white hover:bg-white/10",
              ]}
            >
              {i.pricing.cta}
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- What's included -->
    <div class="mt-14 mx-auto max-w-3xl">
      <div class="grid gap-3 sm:grid-cols-2">
        {i.pricing.includes.map((item) => (
          <div class="flex items-center gap-3 rounded-lg bg-white/5 px-4 py-3">
            <svg class="h-5 w-5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-white/80">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Booking anchor -->
<section id="boka" class="bg-sand py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="font-heading text-2xl font-bold text-ocean sm:text-3xl">Boka din båttur</h2>
    <p class="mt-3 text-text/70">Klicka nedan för att boka via vårt bokningssystem</p>
    <a
      href="https://lets-boat.letsbook.app/sv-se/form/boats?boatModelId=f000715e-a251-42c5-b181-62566984bc42&dockId=e8fa42df-57d7-4d40-b5fd-6680c040d90e"
      target="_blank"
      rel="noopener"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-cyan px-8 py-4 text-base font-semibold text-ocean shadow-lg shadow-cyan/25 transition-all hover:scale-105 hover:bg-cyan-dark hover:shadow-cyan/40"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      Boka nu
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</section>
