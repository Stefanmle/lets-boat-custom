---
import { t } from "@/i18n";
const i = t();
---

<section class="bg-sand py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-heading text-3xl font-bold text-ocean sm:text-4xl">{i.included.title}</h2>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {i.included.items.map((item, idx) => (
        <div class="flex items-start gap-3 rounded-xl border border-sand-dark bg-white p-5 transition-colors hover:border-cyan/30">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-cyan/10">
            <svg class="h-4 w-4 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-sm leading-relaxed text-text/80">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
