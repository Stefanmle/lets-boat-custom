---
import { Image } from "astro:assets";
import { t } from "@/i18n";
import heroImg from "@/assets/images/boats-sunset.webp";
const i = t();
const bookingUrl = "https://lets-boat.letsbook.app/sv-se/form/boats?boatModelId=f000715e-a251-42c5-b181-62566984bc42&dockId=e8fa42df-57d7-4d40-b5fd-6680c040d90e";
---

<section class="relative min-h-[100svh] overflow-hidden bg-ocean">
  <!-- Video background (desktop) / Image fallback (mobile) -->
  <div class="absolute inset-0">
    <Image
      src={heroImg}
      alt="Let's Boat elbåtar vid bryggan i Göteborg"
      class="h-full w-full object-cover md:hidden"
      widths={[480, 768]}
      sizes="100vw"
      loading="eager"
    />
    <video
      id="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="hidden h-full w-full object-cover md:block"
      src="/letsboat-video.mp4"
    >
    </video>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-ocean/70 via-ocean/50 to-ocean/80"></div>
  </div>

  <!-- Decorative waves -->
  <div class="absolute inset-0 pointer-events-none">
    <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 200" fill="none" preserveAspectRatio="none">
      <path d="M0 100C360 160 720 40 1080 100C1260 130 1380 80 1440 100V200H0V100Z" fill="white" opacity="0.05" />
      <path d="M0 120C240 80 480 160 720 120C960 80 1200 160 1440 120V200H0V120Z" fill="white" opacity="0.03" />
      <path d="M0 160C360 120 720 180 1080 140C1260 130 1380 170 1440 150V200H0V160Z" fill="white" opacity="0.07" />
    </svg>
  </div>

  <div class="relative mx-auto flex min-h-[100svh] max-w-7xl flex-col items-center justify-center px-4 text-center sm:px-6 lg:px-8">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-cyan/30 bg-white/10 px-4 py-2 backdrop-blur-md">
      <span class="h-2 w-2 animate-pulse rounded-full bg-cyan"></span>
      <span class="text-xs font-semibold tracking-widest text-cyan uppercase">100% Elektrisk</span>
    </div>

    <h1 class="font-heading text-4xl font-bold leading-[1.1] text-white sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">
      {i.hero.title}
      <br />
      <span class="bg-gradient-to-r from-cyan via-cyan to-cyan-dark bg-clip-text text-transparent">
        {i.hero.subtitle}
      </span>
    </h1>

    <!-- Feature pills -->
    <div class="mt-8 flex flex-wrap justify-center gap-2.5 sm:gap-3">
      {i.hero.features.map((feature) => (
        <div class="flex items-center gap-2 rounded-full bg-white/10 px-4 py-2.5 backdrop-blur-md">
          <svg class="h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm font-medium text-white/90">{feature}</span>
        </div>
      ))}
    </div>

    <!-- Price + CTA -->
    <p class="mt-6 font-heading text-xl font-bold text-white sm:text-2xl">Från 250 kr/person &bull; Boka på 30 sekunder</p>

    <div class="mt-5 flex flex-col items-center gap-4 sm:flex-row">
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener"
        class="group inline-flex items-center gap-2.5 rounded-full bg-cyan px-9 py-4.5 text-base font-bold text-ocean shadow-2xl shadow-cyan/30 transition-all duration-300 hover:scale-105 hover:bg-cyan-dark hover:shadow-cyan/50 sm:text-lg"
      >
        {i.hero.cta}
        <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#upplevelser"
        class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/5 px-7 py-4 text-sm font-medium text-white/90 backdrop-blur-sm transition-all hover:bg-white/15"
      >
        {i.nav.experiences}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>

    <!-- Review badges -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      <a href="https://www.google.com/maps/place/Let%C2%B4s+Boat/@57.7110522,11.9623319,17z/data=!3m1!4b1!4m6!3m5!1s0x464ff3d1b9b45d51:0xc02f276620d8b0e7!8m2!3d57.7110494!4d11.9649122!16s%2Fg%2F11q_6125d6" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 backdrop-blur-md transition-colors hover:bg-white/20">
        <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <span class="text-sm font-semibold text-white">4.9</span>
        <div class="flex">
          {[1,2,3,4,5].map(() => (
            <svg class="h-3 w-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-xs text-white/50">(126)</span>
      </a>
      <a href="https://www.tripadvisor.com/Attraction_Review-g189894-d23111918-Reviews-Lets_Boat-Gothenburg_Vastra_Gotaland_County_West_Coast.html" target="_blank" rel="noopener" class="flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 backdrop-blur-md transition-colors hover:bg-white/20">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#00AF87"/><circle cx="8.5" cy="12" r="2.5" fill="white"/><circle cx="15.5" cy="12" r="2.5" fill="white"/><circle cx="8.5" cy="12" r="1.2" fill="#00AF87"/><circle cx="15.5" cy="12" r="1.2" fill="#00AF87"/><path d="M12 7L14.5 9.5H9.5L12 7Z" fill="white"/></svg>
        <span class="text-sm font-semibold text-white">4.9</span>
        <div class="flex">
          {[1,2,3,4,5].map(() => (
            <svg class="h-3 w-3 text-[#00AF87]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-xs text-white/50">(139)</span>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="h-6 w-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
      </svg>
    </div>
  </div>
</section>

<script>
  // Ensure video plays on desktop
  const video = document.getElementById("hero-video") as HTMLVideoElement | null;
  if (video && window.matchMedia("(min-width: 768px)").matches) {
    video.play().catch(() => {});
  }
</script>
